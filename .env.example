# Client / API base (desktop app)
API_URL=https://api.autoflow.app
API_TIMEOUT=10

# Flask API (Railway / local)
DATABASE_URL=postgresql://user:password@host:5432/dbname
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
SECRET_KEY=your-secret-key-here
LICENSE_SALT=random-salt-here

# Optional: direct download link for GET /api/version
DOWNLOAD_URL=https://github.com/your-org/autoflow/releases/latest

# Optional: comma-separated CORS origins (defaults include autoflow.app + local dev)
# CORS_ORIGINS=https://autoflow.app,https://www.autoflow.app,http://localhost:3000
