# Client / API base (desktop app)
API_URL=https://api.typestra.com
API_TIMEOUT=10

# Flask API (Railway / local)
DATABASE_URL=postgresql://user:password@host:5432/dbname
REDIS_URL=redis://localhost:6379/0
# Optional explicit Flask-Limiter storage URI. Defaults to REDIS_URL, then memory:// for local dev.
# RATE_LIMIT_STORAGE_URI=redis://localhost:6379/0
# Local/dev only: create missing DB tables on request startup. Production should use Alembic.
AUTO_INIT_DB=0
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_SOLO=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_TEAM=price_...
STRIPE_PRICE_SOLO_ANNUAL=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_TEAM_ANNUAL=price_...
RESEND_API_KEY=re_...
SECRET_KEY=your-secret-key-here
LICENSE_SALT=random-salt-here
ADMIN_SECRET=your_secret_here

# Optional: direct download link for GET /api/version
DOWNLOAD_URL=https://typestra.com/download

# Optional: comma-separated CORS origins (defaults include typestra.com + local dev)
# CORS_ORIGINS=https://typestra.com,https://www.typestra.com,http://localhost:3000
